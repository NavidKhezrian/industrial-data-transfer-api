# ============================================================
# Python
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so

# ============================================================
# Virtual environments
# ============================================================
.venv/
venv/
env/
ENV/

# ============================================================
# uv
# ============================================================
.uv/
uv.lock

# ============================================================
# Environment variables and local secrets
# ============================================================
.env
.env.*
*.env

# ============================================================
# Local configuration backup files
# Keep config.yaml tracked, but ignore local/private copies.
# ============================================================
config.local.yaml
config.production.yaml
config.*.local.yaml
config.*.production.yaml
*.bak
*.backup

# ============================================================
# Factory database and local data
# Do not commit real factory databases or exported batches.
# ============================================================
data/*.db
data/*.sqlite
data/*.sqlite3
data/fuse_monitoring.db
data/agent_state.json
data/agent_batches/
data/snapshots/
data/tmp/
data/temp/

# ============================================================
# Exported data files
# ============================================================
*.parquet
*.metadata.json
*.checksum
*.sha256

# ============================================================
# Logs
# ============================================================
logs/
*.log
*.log.*
debug.log

# ============================================================
# Test and coverage output
# ============================================================
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.mypy_cache/
.ruff_cache/

# ============================================================
# IDE and OS files
# ============================================================
.vscode/
.idea/
.DS_Store
Thumbs.db
desktop.ini

# ============================================================
# Temporary files
# ============================================================
*.tmp
*.temp
*.swp
*.swo
~$*
