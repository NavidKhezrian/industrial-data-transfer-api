# ============================================================
# Python
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so

# ============================================================
# Virtual environments
# ============================================================
.venv/
venv/
env/
ENV/

# ============================================================
# uv
# ============================================================
.uv/
uv.lock

# ============================================================
# Environment variables and local secrets
# ============================================================
.env
.env.*
*.env

# ============================================================
# Local configuration backup files
# Keep config.yaml tracked, but ignore local/private copies.
# ============================================================
config.local.yaml
config.production.yaml
config.*.local.yaml
config.*.production.yaml
*.bak
*.backup

# ============================================================
# Receiver storage and metadata
# Do not commit received factory data or metadata databases.
# ============================================================
storage/
data/storage/
data/raw/
data/tmp/
data/temp/
data/receiver_metadata.sqlite
data/metadata.db
*.sqlite
*.sqlite3
*.db

# ============================================================
# Received/exported data files
# ============================================================
*.parquet
*.metadata.json
*.checksum
*.sha256

# ============================================================
# Logs
# ============================================================
logs/
*.log
*.log.*
debug.log

# ============================================================
# Test and coverage output
# ============================================================
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.mypy_cache/
.ruff_cache/

# ============================================================
# IDE and OS files
# ============================================================
.vscode/
.idea/
.DS_Store
Thumbs.db
desktop.ini

# ============================================================
# Temporary files
# ============================================================
*.tmp
*.temp
*.swp
*.swo
~$*
